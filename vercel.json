{
  "name": "ridex",
  "version": 2,
  "builds": [
    {
      "src": "RideX/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/RideX/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://ridex-backend-0cx5.onrender.com",
    "NODE_ENV": "production"
  }
}
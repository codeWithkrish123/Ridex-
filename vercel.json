{
  "name": "ridex",
  "buildCommand": "cd RideX && npm run build",
  "outputDirectory": "RideX/dist",
  "installCommand": "cd RideX && npm install",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/RideX/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://ridex-backend-0cx5.onrender.com"
  }
}